# Copy to .env.local for local experiments.
# .env.local is gitignored; do not commit real provider URLs or keys.

# Remote providers must be explicitly enabled for local tests.
OPENLOCUS_ALLOW_REMOTE=0

# Embedding provider config.
# OPENLOCUS_EMBEDDING_PROVIDER=openai_compatible
# OPENLOCUS_EMBEDDING_BASE_URL=https://example.invalid/v1
# OPENLOCUS_EMBEDDING_API_KEY=replace-me
# OPENLOCUS_EMBEDDING_MODEL=text-embedding-3-small
# OPENLOCUS_EMBEDDING_DIMENSIONS=1536

# LLM provider config.
# OPENLOCUS_LLM_PROVIDER=openai_compatible
# OPENLOCUS_LLM_BASE_URL=https://example.invalid/v1
# OPENLOCUS_LLM_API_KEY=replace-me
# OPENLOCUS_LLM_MODEL=gpt-4.1-mini

# Research safety policy.
# Keep at 1 unless explicitly running higher-data experiments.
OPENLOCUS_REMOTE_DATA_LEVEL=1
