  "risk_control_records": [
    {
      "anonymous_risk_control_id": "haaer1risk0000",
      "mitigation_bucket": "HAAE-R1 publishes aggregate buckets only; forbidden_scan blocks raw per-task/paths/orders/labels keys, private root paths, file extensions in values, hashes, and CI ids; every record carries aggregate_buckets_only_bool=true, private_root_only_bool=true, no_raw_release_bool=true.",
      "risk_bucket": "private_diagnostic_leakage",
      "risk_controlled_bool": true,
      "risk_description_bucket": "the feasibility inventory could leak per-task diagnostics/paths/candidates/orders/labels into the public artifact."
    },
    {
      "anonymous_risk_control_id": "haaer1risk0001",
      "mitigation_bucket": "every record carries no_replay_bool/no_scoring_bool/no_retrieval_bool/no_candidate_generation_bool/no_haae_layer_execution_bool=true; stop/go carries haae_r1_replay_authorized_bool=false, haae_r1_scoring_authorized_bool=false, etc.",
      "risk_bucket": "haae_r1_scope_creep_beyond_feasibility_inventory",
      "risk_controlled_bool": true,
      "risk_description_bucket": "HAAE-R1 could be scoped beyond a feasibility inventory into replay/scoring/retrieval/candidate generation/HAAE-layer execution."
    },
    {
      "anonymous_risk_control_id": "haaer1risk0002",
      "mitigation_bucket": "default mode (no --allow-private-inventory) produces the unavailable_no_explicit_private_roots artifact; real inventory requires explicit --allow-private-inventory --private-root; the safe parser rejects unknown args generically without echoing values.",
      "risk_bucket": "haae_r1_default_mode_reads_private_roots",
      "risk_controlled_bool": true,
      "risk_description_bucket": "the default/no-private mode could silently read private roots without explicit opt-in."
    },
    {
      "anonymous_risk_control_id": "haaer1risk0003",
      "mitigation_bucket": "every record carries the HAAE-R0 non-identity booleans; selector_reranker_authorized_bool=false; bea_v1_a_authorized_bool=false; p5_authorized_bool=false; runtime_default_change_authorized_bool=false.",
      "risk_bucket": "haae_r0_drift_into_selector_or_p5_or_runtime",
      "risk_controlled_bool": true,
      "risk_description_bucket": "the HAAE-R1 inventory could be reframed as BEA-v1-A, a selector-only design, selector/reranker execution, P5, or a runtime/default promotion."
    },
    {
      "anonymous_risk_control_id": "haaer1risk0004",
      "mitigation_bucket": "runtime_default_change_authorized_bool=false; any HAAE route remains opt-in/eval-only; no runtime or default change.",
      "risk_bucket": "runtime_default_creep",
      "risk_controlled_bool": true,
      "risk_description_bucket": "the feasibility inventory could implicitly drift runtime/default behavior by codifying a route as a default gate."
    },
    {
