{
  "schema_version": "p21-g-model-profiles-v1",
  "purpose": "Cross-model context-injection research model profiles for OpenLocus P21-G.",
  "policy": {
    "candidate_not_fact": true,
    "evidence_authority": "EvidenceCore current-source read + content_sha/range validation",
    "remote_runs_require": "workflow_dispatch + enable_remote_models=true + OPENLOCUS_ALLOW_REMOTE=1",
    "excluded_remote_inputs": [
      "secrets",
      "ignored_files",
      "provider_keys",
      "private_labels",
      "gold_answers"
    ],
    "rich_context_allowed_on_public_or_opt_in_runs": true,
    "promotion_ready": false,
    "default_should_change": false
  },
  "defaults": {
    "dataset": "ci_smoke",
    "repos": ["py_flask", "js_express", "go_gin", "rust_ripgrep"],
    "max_tasks": 20,
    "max_records": 80,
    "max_files_per_repo": 120,
    "max_workflow_runs_per_batch": 20,
    "llm_stage": "p20_llm_large",
    "embedding_stage": "p21_embedding_context",
    "embedding_strategies": "atom_path_symbol,atom_signature,atom_matched_lines,atom_body_window,pack1_metadata,pack2_evidence_sketch,pack3_local_code,pack5_contrastive",
    "embedding_model_for_llm_stage": "BAAI/bge-m3"
  },
  "autonomous_run_policy": {
    "smoke": {
      "max_tasks": 20,
      "repos": ["py_flask", "js_express", "go_gin", "rust_ripgrep"],
      "all_enabled_models": true
    },
    "medium": {
      "max_tasks": 60,
      "repos": ["py_flask", "js_express", "go_gin", "rust_ripgrep"],
      "only_promising_profiles": true
    },
    "stop_rules": {
      "added_false_to_gold_ratio_stop": 3.0,
      "schema_violation_rate_stop": 0.05,
      "fabricated_identifier_rate_alias_requires_inventory_filter": 0.2,
      "pfp_increase_blocks_role": true,
      "repeat_rate_limit_or_provider_failures_pause_batch": true,
      "large_expansion_requires_positive_smoke_and_medium": true
    }
  },
  "llm_profiles": [
    {
      "profile_id": "deepseek_v4_flash_small_fast",
      "model_id": "[mk]DeepSeek-V4-Flash",
      "family": "small_fast",
      "enabled_by_default": true,
      "provider": "OPENLOCUS_LLM_PROVIDER",
      "roles_planned": ["filter", "inventory_alias", "abstain", "rerank"],
      "effective_context_bucket": "long",
      "advertised_context_tokens": 1000000,
      "approx_decode_tokens_per_second": 300,
      "cost_class": "low_or_medium",
      "latency_class": "fast",
      "notes": "150B-class fast long-context model. Use as the small/fast profile and latency baseline; good for first-pass filter, abstain, and cheap rerank tests."
    },
    {
      "profile_id": "kimi_k2_7_code",
      "model_id": "[mk]Kimi-K2.7-Code",
      "family": "code",
      "enabled_by_default": true,
      "provider": "OPENLOCUS_LLM_PROVIDER",
      "roles_planned": ["rerank", "filter", "span_narrow", "inventory_alias", "abstain"],
      "effective_context_bucket": "long",
      "advertised_context_tokens": 256000,
      "approx_decode_tokens_per_second": 330,
      "cost_class": "medium_or_high",
      "latency_class": "fast_for_size",
      "notes": "1.1T-class strongest coding profile in the current roster. P20-LS-A low-context alias mode failed on this model; reuse as the primary code model for grounded context-injection roles."
    },
    {
      "profile_id": "qwen3_6_27b_code_balanced",
      "model_id": "[mk]Qwen3.6-27B",
      "family": "code_balanced",
      "enabled_by_default": true,
      "provider": "OPENLOCUS_LLM_PROVIDER",
      "roles_planned": ["rerank", "filter", "span_narrow", "abstain"],
      "effective_context_bucket": "medium_long",
      "advertised_context_tokens": 128000,
      "approx_decode_tokens_per_second": 180,
      "cost_class": "medium",
      "latency_class": "balanced",
      "notes": "New mid-size Qwen code/reasoning profile added for Breakthrough Sprint cross-model breadth. Use for live rich-candidate span_narrow/filter/rerank comparisons against Kimi, GLM, and DeepSeek."
    },
    {
      "profile_id": "deepseek_v4_pro_long_context",
      "model_id": "[mk]DeepSeek-V4-Pro",
      "family": "long_context",
      "enabled_by_default": true,
      "provider": "OPENLOCUS_LLM_PROVIDER",
      "roles_planned": ["rerank", "filter", "span_narrow", "abstain"],
      "effective_context_bucket": "long",
      "advertised_context_tokens": 1000000,
      "approx_decode_tokens_per_second": 110,
      "cost_class": "high",
      "latency_class": "slow",
      "notes": "1.8T-class strongest text/long-context profile. Use for Pack5/Pack6, long-layout tests, hard distractor contrast, and leave-one-family-out validation."
    },
    {
      "profile_id": "glm_5_2_reasoning_code",
      "model_id": "[mk]GLM-5.2",
      "family": "reasoning_code_strong",
      "enabled_by_default": true,
      "provider": "OPENLOCUS_LLM_PROVIDER",
      "roles_planned": ["rerank", "filter", "span_narrow", "abstain"],
      "effective_context_bucket": "medium_long",
      "advertised_context_tokens": 200000,
      "approx_decode_tokens_per_second": 130,
      "cost_class": "high",
      "latency_class": "balanced_slow",
      "notes": "Updated GLM reasoning/code profile for the active roster. Use as the strong review/ablation model and as a contrast against Kimi code, Qwen, and DeepSeek long-context behavior."
    }
  ],
  "embedding_profiles": [
    {
      "profile_id": "bge_m3",
      "model_id": "BAAI/bge-m3",
      "family": "multilingual_dense",
      "enabled_by_default": true,
      "dimensions": 1024,
      "send_dimensions": false,
      "roles_planned": ["file_locator", "candidate_generator", "bq_diagnostic"]
    },
    {
      "profile_id": "qwen3_embedding_0_6b",
      "model_id": "Qwen/Qwen3-Embedding-0.6B",
      "family": "embedding_small_fast",
      "enabled_by_default": true,
      "dimensions": 1024,
      "send_dimensions": true,
      "roles_planned": ["file_locator", "candidate_generator", "bq_diagnostic"]
    },
    {
      "profile_id": "qwen3_embedding_4b",
      "model_id": "Qwen/Qwen3-Embedding-4B",
      "family": "embedding_balanced",
      "enabled_by_default": true,
      "dimensions": 2560,
      "send_dimensions": true,
      "roles_planned": ["file_locator", "candidate_generator", "bq_diagnostic"]
    },
    {
      "profile_id": "qwen3_embedding_8b",
      "model_id": "Qwen/Qwen3-Embedding-8B",
      "family": "embedding_large",
      "enabled_by_default": true,
      "dimensions": 4096,
      "send_dimensions": true,
      "roles_planned": ["file_locator", "candidate_generator", "bq_diagnostic"]
    }
  ]
}
